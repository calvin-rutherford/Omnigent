# Database (Postgres)
DATABASE_URL=postgres://omnigent:password@localhost:5432/omnigent_db

# RabbitMQ / Celery
CELERY_BROKER_URL=amqp://omnigent:password@localhost:5672//
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Django Channels / Redis
CHANNEL_LAYER_REDIS_URL=redis://localhost:6379/1

# LLM Providers (Add the key for the provider you want to use)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_LLM_MODEL=gemini/gemini-1.5-pro

# Django configuration
SECRET_KEY=dev-secret-key
DEBUG=True
